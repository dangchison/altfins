# Altfins credentials
ALTFINS_ACCOUNT=
ALTFINS_PASSWORD=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Telegram Chat IDs per source type
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_ANALYSIS=-100group1
TELEGRAM_CHAT_ID_PATTERN=-100group2
TELEGRAM_CHAT_ID_HIGHLIGHT=-100group3

# Scraper Behaviour
TECHNICAL_ANALYSIS_MAX_ROWS=2
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_CHART_PATTERNS=true
ENABLE_MARKET_HIGHLIGHTS=true

# Session Management
# Set to 'false' for local development to avoid syncing auth_state.json with Supabase
USE_PERSISTENT_SESSION=true