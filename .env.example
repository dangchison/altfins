# Altfins credentials
ALTFINS_ACCOUNT=
ALTFINS_PASSWORD=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Telegram — nhiều group cách nhau bởi dấu phẩy
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=-100group1,-100group2

# Scraper Behaviour
TECHNICAL_ANALYSIS_MAX_ROWS=2
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_CHART_PATTERNS=true
ENABLE_MARKET_HIGHLIGHTS=true

# Session Management
# Set to 'false' for local development to avoid syncing auth_state.json with Supabase
USE_PERSISTENT_SESSION=true